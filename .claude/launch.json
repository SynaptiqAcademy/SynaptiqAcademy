{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "venv/bin/uvicorn",
      "runtimeArgs": ["server:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "cwd": "backend",
      "port": 8000,
      "autoPort": true
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "cwd": "frontend",
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "frontend-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "cwd": "frontend",
      "port": 3001,
      "autoPort": true
    }
  ]
}
